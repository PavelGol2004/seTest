# Базовый URL API. Пустое значение = запросы на тот же хост, что и Vite (см. прокси ниже).
# Mock: http://localhost:3001
# Реальный API (если на бэкенде настроен CORS): http://localhost:5187
VITE_API_URL=

# Цель dev-прокси Vite (обход CORS). Используется только когда VITE_API_URL пустой.
# Пример для локального SmartEvent.Backend (профиль http в launchSettings):
DEV_API_PROXY_TARGET=http://localhost:5187
